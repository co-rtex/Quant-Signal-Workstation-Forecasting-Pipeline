APP_ENV=local
APP_NAME=quant-signal-workstation
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/quant_signal
ARTIFACT_ROOT=artifacts
BENCHMARK_SYMBOL=SPY
UNIVERSE_SYMBOLS=AAPL,MSFT,GOOGL,AMZN,NVDA,META,SPY
DEFAULT_HORIZONS=1,5,20
TOP_N_SIGNALS=10
MIN_TRAINING_DAYS=252
MARKET_DATA_PROVIDER=yfinance
MARKET_DATA_MAX_ATTEMPTS=1
MARKET_DATA_BACKOFF_SECONDS=1.0
MARKET_DATA_BACKOFF_MULTIPLIER=2.0
BACKTEST_TRANSACTION_COST_BPS=0.0
BACKTEST_SLIPPAGE_BPS=0.0
